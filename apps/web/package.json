    "@tanstack/react-start": "^1.168.27",
    "better-auth": "^1.6.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dotenv": "^17.4.2",
    "katex": "^0.17.0",
    "kysely": "^0.29.3",
    "kysely-d1": "^0.4.0",
    "lucide-react": "^0.479.0",
