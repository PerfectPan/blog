# Local dev env loaded by dotenv (`vite dev`). Copy to .env (gitignored).
# For `wrangler dev` / preview, the same values go in .dev.vars (see
# .dev.vars.example). In production these are set via `wrangler secret put` /
# the `[vars]` block in wrangler.jsonc — not from this file.
#
# Note: the retired Vercel + Payload + Postgres stack used DATABASE_URL /
# PAYLOAD_* / ENABLE_MARKDOWN_FALLBACK — none of those exist anymore.

# Required: HMAC key for Better Auth sessions + signed unlock cookies.
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-long-random-secret

# Public origin of the site.
APPS_WEB_URL=http://localhost:3000

# Optional: GitHub OAuth. Leave unset to disable the GitHub sign-in button.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Optional: cookie domain and first-admin allowlist.
COOKIE_DOMAIN=
ADMIN_EMAIL_ALLOWLIST=
