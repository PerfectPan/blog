{
  "name": "blog",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @blog/web dev",
    "build": "pnpm --filter @blog/web build",
    "deploy": "pnpm --filter @blog/web deploy",
    "db:migrate": "pnpm --filter @blog/web db:migrate",
    "db:migrate:local": "pnpm --filter @blog/web db:migrate:local",
    "cf-typegen": "pnpm --filter @blog/web cf-typegen",
    "test:e2e": "playwright test",
    "test:e2e:logout": "playwright test tests/e2e/auth-logout.spec.ts",
    "typecheck": "pnpm --recursive --filter @blog/web --filter @blog/shared typecheck",
    "prepare": "husky"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@biomejs/biome": "1.9.4",
    "autoprefixer": "10.4.17",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.5",
    "tailwindcss": "3.4.1",
    "typescript": "^5.7.3"
  },
  "lint-staged": {
    "*.{mjs,js,jsx,mts,ts,tsx,css,json,md}": "pnpm biome check --write"
  },
  "packageManager": "pnpm@8.15.5"
}
